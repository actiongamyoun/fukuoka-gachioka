# Supabase (Project Settings > API에서 복사)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps API (Step 4에서 사용 예정)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key

# 카카오 OAuth는 Supabase Dashboard > Authentication > Providers > Kakao에서 설정
# 클라이언트 코드에는 별도 키 불필요
